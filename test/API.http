GET {{baseUrl}}/api/v1/providers/{{providerId}}/buckets/{{bucketName}}/search?
    query={{$random.alphanumeric(8)}}&
    path={{$random.alphanumeric(8)}}&
    maxResults={{$random.integer(100)}}